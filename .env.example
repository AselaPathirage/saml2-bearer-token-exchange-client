# ─── Session ──────────────────────────────────────────────────────────────────
SESSION_SECRET=change-this-to-a-random-secure-string

# ─── SAML Service Provider ────────────────────────────────────────────────────
# Must match the Issuer (SP Entity ID) configured on the IS service provider.
SP_ENTITY_ID=SAMLApp

# Must match the Assertion Consumer URL (ACS URL) on the IS service provider.
SP_CALLBACK_URL=http://localhost:3000/callback

# ─── WSO2 Identity Server 6.1.0 (SAML IdP) ───────────────────────────────────
# IS SSO endpoint — default IS port is 9443; use 9444 if IS runs with port offset 1.
IDP_SSO_URL=https://localhost:9444/samlsso

# IS Single Logout endpoint
IDP_LOGOUT_URL=https://localhost:9444/samlsso

# App SLO callback — IS redirects here after completing logout
SP_LOGOUT_CALLBACK_URL=http://localhost:3000/logout/callback

# IS public certificate in PEM format 
IDP_CERT_PATH=./certs/is-public.pem

# SP signing key/cert — required when IS SP has "Enable Signature Validation" checked.
# Generate with: openssl req -x509 -newkey rsa:2048 -keyout certs/sp-private.pem -out certs/sp-public.pem -days 365 -nodes -subj "/CN=SAMLApp"
SP_PRIVATE_KEY_PATH=./certs/sp-private.pem
SP_CERT_PATH=./certs/sp-public.pem

# ─── WSO2 API Manager 4.2.0 ───────────────────────────────────────────────────
# Add this value as an Audience in the IS SP SAML2 configuration.
APIM_TOKEN_ENDPOINT=https://localhost:9443/oauth2/token
APIM_CONSUMER_KEY=your-consumer-key-from-apim-devportal
APIM_CONSUMER_SECRET=your-consumer-secret-from-apim-devportal

# The API endpoint to invoke through the APIM Gateway
# e.g. https://localhost:8243/pizzashack/1.0.0/menu
APIM_API_ENDPOINT=https://localhost:8243/your-api/v1/resource

# ─── App ─────────────────────────────────────────────────────────────────────
PORT=3000
